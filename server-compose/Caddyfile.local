{
  auto_https off
}

http://odin.webui, http://odin.openwebui {
  handle /immich-photo* {
    reverse_proxy 127.0.0.1:2290
  }

  handle {
    reverse_proxy 127.0.0.1:3000
  }
}

http://odin.immich {
  reverse_proxy 127.0.0.1:2283
}

http://odin.nextcloud {
  reverse_proxy 127.0.0.1:8082
}

http://odin.homeassistant, http://odin.ha {
  reverse_proxy 127.0.0.1:8123 {
    header_up Host 192.168.1.133:8123
    header_up -X-Forwarded-For
    header_up -X-Real-IP
  }
}

http://odin.n8n {
  reverse_proxy 127.0.0.1:5679
}

http://odin.netdata {
  reverse_proxy 127.0.0.1:19999
}

http://odin.frigate {
  reverse_proxy https://127.0.0.1:8971 {
    transport http {
      tls_insecure_skip_verify
    }
  }
}

http://odin.qdrant {
  reverse_proxy 127.0.0.1:6333
}

http://odin.stirling {
  reverse_proxy 127.0.0.1:8080
}

http://odin.crawl {
  reverse_proxy 127.0.0.1:11235
}

http://odin.evolution {
  reverse_proxy 127.0.0.1:8085
}

http://odin.piper {
  reverse_proxy 127.0.0.1:10200
}

http://odin.whisper {
  reverse_proxy 127.0.0.1:10301
}

http://odin.asr {
  reverse_proxy 127.0.0.1:5002
}

http://odin.tts {
  reverse_proxy 127.0.0.1:49112
}

http://odin.ollama {
  reverse_proxy 127.0.0.1:11434
}

http://odin.mealie {
  reverse_proxy 127.0.0.1:9925
}
